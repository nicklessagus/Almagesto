# Token ADS: NUNCA commitearlo. Ponelo en config/ads_dev_key (gitignored) o en la
# variable de entorno ADS_DEV_KEY. Token gratis: https://ui.adsabs.harvard.edu/user/settings/token
config/ads_dev_key

# Cachés Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Intermedios de ingesta (se regeneran con los scripts)
build/

# Reportes de lint (regenerables)
outputs/

# Datos crudos (la bóveda referencia, no aloja)
*.fits
*.pkl

# Obsidian: se commitea la config compartible (.obsidian/app.json, appearance.json,
# core-plugins.json, community-plugins.json, plugins/, snippets/, themes/, hotkeys.json...);
# se ignora lo volátil/por-máquina (layout de ventanas y caché).
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
# Plugins de comunidad (Dataview, etc.): se instalan desde Obsidian, no se versionan.
.obsidian/plugins/

# Sistema
.DS_Store
