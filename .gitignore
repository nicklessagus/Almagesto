# Token ADS: NUNCA commitearlo. Ponelo en vault/config/ads_dev_key (gitignored) o en la
# variable de entorno ADS_DEV_KEY. Token gratis: https://ui.adsabs.harvard.edu/user/settings/token
vault/config/ads_dev_key

# Cachés Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Intermedios de ingesta y reportes de lint (regenerables): scratch del tooling, viven en
# la raíz del repo FUERA de vault/ para no contaminar la bóveda de Obsidian.
build/
outputs/

# Datos crudos (la bóveda referencia, no aloja)
*.fits
*.pkl

# Obsidian (la bóveda se abre en vault/): se commitea la config compartible
# (vault/.obsidian/app.json, appearance.json, core-plugins.json, community-plugins.json,
# plugins/, snippets/, themes/, hotkeys.json...); se ignora lo volátil/por-máquina.
# Un .obsidian/ en la RAÍZ es siempre un error (repo abierto como vault → el grafo indexa
# andamiaje); se ignora para que no se commitee por accidente — el lint además lo marca WARN.
/.obsidian/
vault/.obsidian/workspace.json
vault/.obsidian/workspace-mobile.json
vault/.obsidian/cache
# Plugins de comunidad (Dataview, etc.): se instalan desde Obsidian, no se versionan.
vault/.obsidian/plugins/

# Hooks generados por git-lfs: con core.hooksPath = scripts/hooks, `git lfs install` los
# escribe acá (adentro del working tree). Son shims estándar por-máquina — no se versionan.
scripts/hooks/post-checkout
scripts/hooks/post-commit
scripts/hooks/post-merge
scripts/hooks/pre-push

# Sistema
.DS_Store
