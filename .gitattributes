# git-lfs: PDFs de las fuentes
vault/raw/pdfs/**/*.pdf filter=lfs diff=lfs merge=lfs -text

# ── Sync template-as-upstream ────────────────────────────────────────────────
# Archivos "propios de la instancia": al traer mejoras del framework
# (`git pull` o `git merge upstream/main`) se conserva SIEMPRE la versión local
# (nunca la del template). Registrar el driver una vez por clon:
#     git config merge.ours.driver true
vault/config/objective.yaml merge=ours
vault/config/stars.yaml     merge=ours
vault/config/topics.yaml    merge=ours
vault/STATUS.md             merge=ours
vault/wiki/index.md         merge=ours
vault/wiki/log.md           merge=ours
vault/wiki/matrices/method_star.md merge=ours
